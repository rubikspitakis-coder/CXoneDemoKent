generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Member {
  id                   String   @id @default(uuid())
  phone                String   @unique
  firstName            String
  lastName             String
  email                String   @default("")
  company              String   @default("")
  jobTitle             String   @default("")
  membershipType       String   @default("Member")
  status               String   @default("Active")
  cpdHours             Int      @default(0)
  cpdTarget            Int      @default(120)
  renewalDate          String   @default("")
  lastContactDate      String   @default("")
  preferredChannel     String   @default("Phone")
  outstandingBalance   Float    @default(0)
  notes                String   @default("")
  lastUpdated          DateTime @updatedAt
}
